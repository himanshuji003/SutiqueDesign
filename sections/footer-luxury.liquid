<style>
  .footer-luxury {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: var(--spacing-2xl) 0 var(--spacing-lg);
  }

  .footer-luxury-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  @media (min-width: 750px) {
    .footer-luxury-container {
      padding: 0 var(--spacing-lg);
    }
  }

  @media (min-width: 990px) {
    .footer-luxury-container {
      padding: 0 var(--spacing-xl);
    }
  }

  .footer-luxury-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-2xl);
  }

  @media (min-width: 750px) {
    .footer-luxury-content {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 990px) {
    .footer-luxury-content {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .footer-section h3 {
    font-size: 1.125rem;
    font-family: var(--font-heading);
    color: {{ section.settings.heading_color }};
    margin-bottom: var(--spacing-md);
    font-weight: 500;
  }

  .footer-section ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-section li {
    margin-bottom: var(--spacing-sm);
  }

  .footer-section a {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .footer-section a:hover {
    color: {{ section.settings.accent_color }};
  }

  .footer-brand-info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .footer-brand-logo {
    width: 120px;
    height: auto;
    object-fit: contain;
  }

  .footer-brand-description {
    font-size: 0.9rem;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
  }

  .footer-social-links {
    display: flex;
    gap: var(--spacing-md);
  }

  .footer-social-link {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: {{ section.settings.text_color }};
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .footer-social-link:hover {
    background-color: {{ section.settings.accent_color }};
    color: {{ section.settings.bg_color }};
  }

  .footer-social-link svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .footer-newsletter {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .newsletter-input-group {
    display: flex;
    gap: 0;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    overflow: hidden;
  }

  .newsletter-input-group input {
    flex: 1;
    border: none;
    background-color: transparent;
    color: {{ section.settings.text_color }};
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: 0.9rem;
  }

  .newsletter-input-group input::placeholder {
    color: rgba(255, 255, 255, 0.7);
  }

  .newsletter-input-group button {
    background-color: {{ section.settings.accent_color }};
    border: none;
    color: {{ section.settings.bg_color }};
    padding: 0 20px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .newsletter-input-group button:hover {
    background-color: rgba(212, 175, 55, 0.9);
  }

  .footer-payment-icons {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    align-items: center;
  }

  .payment-icon {
    width: 40px;
    height: 30px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
  }

  .payment-icon img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--spacing-lg);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
    align-items: center;
  }

  @media (min-width: 750px) {
    .footer-bottom {
      grid-template-columns: 1fr 1fr;
    }
  }

  .footer-copyright {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
  }

  @media (min-width: 750px) {
    .footer-copyright {
      text-align: left;
    }
  }

  .footer-bottom-links {
    display: flex;
    justify-content: center;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
  }

  @media (min-width: 750px) {
    .footer-bottom-links {
      justify-content: flex-end;
    }
  }

  .footer-bottom-links a {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-bottom-links a:hover {
    color: {{ section.settings.accent_color }};
  }
</style>

<footer class="footer-luxury">
  <div class="footer-luxury-container">
    <div class="footer-luxury-content">
      <!-- Brand Info -->
      <div class="footer-section footer-brand-info">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="Logo" class="footer-brand-logo">
        {% else %}
          <h3>{{ section.settings.brand_name }}</h3>
        {% endif %}
        <p class="footer-brand-description">{{ section.settings.brand_description }}</p>
        <div class="footer-social-links">
          {% if section.settings.facebook_link != blank %}
            <a href="{{ section.settings.facebook_link }}" class="footer-social-link" aria-label="Facebook">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 2h-3a6 6 0 0 0-6 6v3H7v4h2v8h4v-8h3l1-4h-4V8a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.instagram_link != blank %}
            <a href="{{ section.settings.instagram_link }}" class="footer-social-link" aria-label="Instagram">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" fill="none" stroke="currentColor" stroke-width="2"/>
                <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.pinterest_link != blank %}
            <a href="{{ section.settings.pinterest_link }}" class="footer-social-link" aria-label="Pinterest">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
                <path d="M8 12c0-1.657.895-3.1 2.236-3.89M16 12c0 1.657-.895 3.1-2.236 3.89" fill="none" stroke="currentColor" stroke-width="2"/>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-section">
        <h3>Quick Links</h3>
        <ul>
          {% if section.settings.link_1_text != blank %}
            <li><a href="{{ section.settings.link_1_url }}">{{ section.settings.link_1_text }}</a></li>
          {% endif %}
          {% if section.settings.link_2_text != blank %}
            <li><a href="{{ section.settings.link_2_url }}">{{ section.settings.link_2_text }}</a></li>
          {% endif %}
          {% if section.settings.link_3_text != blank %}
            <li><a href="{{ section.settings.link_3_url }}">{{ section.settings.link_3_text }}</a></li>
          {% endif %}
          {% if section.settings.link_4_text != blank %}
            <li><a href="{{ section.settings.link_4_url }}">{{ section.settings.link_4_text }}</a></li>
          {% endif %}
        </ul>
      </div>

      <!-- Customer Support -->
      <div class="footer-section">
        <h3>Customer Support</h3>
        <ul>
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/refund-policy">Refund & Returns</a></li>
          <li><a href="/policies/shipping-policy">Track Order</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="/pages/faq">FAQs</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="footer-section footer-newsletter">
        <h3>Newsletter</h3>
        <p style="font-size: 0.9rem;">Subscribe to get exclusive offers & early access to new collections.</p>
        <form class="newsletter-input-group" method="post" action="/contact#Contact-form">
          <input type="email" name="email" placeholder="Enter your email" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>

      <!-- Payment Methods -->
      <div class="footer-section">
        <h3>Payment Methods</h3>
        <div class="footer-payment-icons">
          <div class="payment-icon" title="Visa">
            <svg viewBox="0 0 48 32" xmlns="http://www.w3.org/2000/svg" style="fill: {{ section.settings.text_color }};">
              <rect width="48" height="32" rx="4"/>
              <text x="24" y="20" text-anchor="middle" font-size="10" font-weight="bold" fill="currentColor">VISA</text>
            </svg>
          </div>
          <div class="payment-icon" title="Mastercard">
            <svg viewBox="0 0 48 32" xmlns="http://www.w3.org/2000/svg">
              <circle cx="16" cy="16" r="8" fill="#FF5F00"/>
              <circle cx="32" cy="16" r="8" fill="#EB001B"/>
            </svg>
          </div>
          <div class="payment-icon" title="PayPal">
            <svg viewBox="0 0 48 32" xmlns="http://www.w3.org/2000/svg" style="fill: {{ section.settings.text_color }};">
              <text x="24" y="20" text-anchor="middle" font-size="8" font-weight="bold">PayPal</text>
            </svg>
          </div>
          <div class="payment-icon" title="UPI">
            <svg viewBox="0 0 48 32" xmlns="http://www.w3.org/2000/svg" style="fill: {{ section.settings.text_color }};">
              <text x="24" y="20" text-anchor="middle" font-size="8" font-weight="bold">UPI</text>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <div class="footer-copyright">
        © {{ "now" | date: "%Y" }} {{ section.settings.copyright_text }}. All rights reserved.
      </div>
      <div class="footer-bottom-links">
        <a href="/policies/privacy-policy">Privacy</a>
        <a href="/policies/terms-of-service">Terms</a>
        <a href="/pages/contact">Contact</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer Luxury",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "Ethnara"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand Description",
      "default": "Premium handcrafted Indian ethnic wear for the modern woman. Celebrating artistry, tradition, and timeless elegance."
    },
    {
      "type": "url",
      "id": "facebook_link",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram_link",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "pinterest_link",
      "label": "Pinterest URL"
    },
    {
      "type": "text",
      "id": "link_1_text",
      "label": "Link 1 Text",
      "default": "Home"
    },
    {
      "type": "url",
      "id": "link_1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "link_2_text",
      "label": "Link 2 Text",
      "default": "Collections"
    },
    {
      "type": "url",
      "id": "link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "link_3_text",
      "label": "Link 3 Text",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "link_4_text",
      "label": "Link 4 Text",
      "default": "Blog"
    },
    {
      "type": "url",
      "id": "link_4_url",
      "label": "Link 4 URL"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Ethnara"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a2b3c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#d4af37"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#d4af37"
    }
  ],
  "presets": [
    {
      "name": "Footer Luxury"
    }
  ]
}
{% endschema %}
